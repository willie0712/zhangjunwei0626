<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html{ scroll-behavior:smooth; }

body{
  font-family:'Inter','Noto Sans TC',sans-serif;
  background: radial-gradient(circle at top,#1e293b 0%,#020617 60%);
  color:white;
  overflow-x:hidden;
}

section{ padding:120px 8%; }

/* NAV */
.navbar{
  position:fixed;
  width:100%;
  top:0;
  z-index:999;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20px 8%;
  background:rgba(2,6,23,0.65);
  backdrop-filter:blur(18px);
  border-bottom:1px solid rgba(255,255,255,0.05);
}

.logo{
  font-size:1.2rem;
  font-weight:800;
}

.nav-links{
  display:flex;
  gap:28px;
}

.nav-links a{
  text-decoration:none;
  color:#cbd5e1;
}

/* HERO */
.hero{
  min-height:100vh;
  display:flex;
  align-items:center;
}

.hero-grid{
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:80px;
  align-items:center;
}

.hero h1{
  font-size:clamp(4rem,9vw,7rem);
  line-height:.9;
}

.hero p{
  color:#94a3b8;
  line-height:2;
}

/* BUTTON */
.btn{
  padding:14px 28px;
  border-radius:999px;
  text-decoration:none;
  font-weight:700;
}

.primary{
  background:linear-gradient(135deg,#38bdf8,#0ea5e9);
  color:white;
}

.secondary{
  border:1px solid rgba(255,255,255,.1);
  color:white;
}

/* HERO IMAGE FIX */
.hero-image img{
  width:100%;
  height:420px;
  object-fit:cover;
  border-radius:30px;
}

/* STATUS */
.status-card{
  margin-top:20px;
  padding:20px;
  background:rgba(255,255,255,.07);
  border-radius:20px;
}

/* ABOUT */
.glass{
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.08);
  border-radius:20px;
  padding:30px;
}

/* PHOTO */
.photo-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
  gap:20px;
}

.photo-grid img{
  width:100%;
  height:300px;
  object-fit:cover;
  border-radius:20px;
}

/* GAME */
.game-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:20px;
}

.game-card{
  background:rgba(255,255,255,.05);
  border-radius:20px;
  overflow:hidden;
}

.game-card img{
  width:100%;
  height:200px;
  object-fit:cover;
}

/* CONTACT */
.contact{
  background:rgba(255,255,255,.05);
  padding:40px;
  border-radius:20px;
}

.contact a{
  color:#38bdf8;
  text-decoration:none;
}

/* FOOTER */
.footer{
  text-align:center;
  padding:60px;
  border-top:1px solid rgba(255,255,255,.1);
  color:#94a3b8;
}

/* MOBILE */
@media(max-width:900px){
  .hero-grid{ grid-template-columns:1fr; }
}
</style>
